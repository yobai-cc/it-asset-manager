[Unit]
Description=IT Asset Manager (Flask/Gunicorn)
After=network.target

[Service]
Type=simple
User=yobai
Group=yobai
WorkingDirectory=/home/yobai/it-asset-manager
Environment="PATH=/home/yobai/it-asset-manager/.venv/bin"
Environment="FLASK_DEBUG=0"
ExecStart=/home/yobai/it-asset-manager/.venv/bin/gunicorn -c gunicorn.conf.py "server:app"
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
